            <section class="auth login" id="loginModal">
                <div class="auth-box">
                    <span id="closeLogin" class="close-btn">&times;</span>

                    <h2>Book faster. Travel smarter.</h2>
                    <p>Enter your email to continue</p>

                    <input type="email" id="emailInput" placeholder="Email address" required>
                    <input class="login-password-input" type="password" id="passwordBox" placeholder="Password" required>

                    <button onclick="checkEmail()">Continue with email</button>

                    <p class="signup-link mt-3 text-center">
                        Don’t have an account?
                        <a href="/create-account">Sign up</a>
                    </p>
                </div>
            </section>

