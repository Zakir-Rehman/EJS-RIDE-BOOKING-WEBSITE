<section class="booking-form">
    <div class="booking-main">
        <div class="booking-main-inner-main">
            <h2 class="head-">Book Your Self-Drive Car</h2>
            <div class="booking-main-inner-main-head">
                <p class="text-xl text-gray-600 max-w-xl mx-auto">Fill out the form below and we'll get back to you
                    with availability and pricing for Pakistani Places.</p>
            </div>
            <form class="space-y-4">
                <div class="fullname-div max-inps"><label for="name" class="">Full Name
                        *</label><input type="text" id="name" required="" class="" placeholder="Your full name"
                        minlength="2" maxlength="50" name="name" value=""></div>
                <div class="max-inps">
                    <label for="phone" class="">Phone Number *</label>
                    <div class="phone-number-input">
                        <button>+92</button>
                        <input type="number" required placeholder="Phone number" min="0">
                    </div>
                </div>
                <div class="max-inps">
                    <label for="car_type" class="">Car
                        Type</label>
                        <select id="car_type" name="car_type" class="rounded-0">
                        <option value="" selected="">Select Car Type</option>
                        <option value="economy">Economy</option>
                        <option value="executive">Executive</option>
                        <option value="luxury">Luxury</option>
                    </select>
                </div>
                <div class="max-inps">
                    <label>Fuel Type</label>
                    <select name="fuelType">
                        
                        <option value="" selected="">Select Fuel Type</option>
                        <option value="Petrol">Petrol</option>
                        <option value="Diesel">Diesel</option>
                        <option value="Hybrid">Hybrid</option>
                        <option value="Electric">Electric</option>
                    </select>
                </div>
                <div class="max-inps">
                    <label>Transmission</label>
                    <select name="transmission">
                        <option value="" selected="">Select Transmission Type</option>
                        <option value="Manual">Manual</option>
                        <option value="Automatic">Automatic</option>
                    </select>
                </div>
                <div class="max-inps">
                    <label>City</label>
                    <select name="city">
                        <option value="" selected="">Select City</option>
                    <option value="Karachi">Karachi</option>
                    <option value="Lahore" >Lahore</option>
                    <option value="Islamabad">Islamabad</option>
                    <option value="Quetta">Quetta</option>
                    </select>
                </div>
                <div class="textarea-div max-inps">
                    <label for="message" class="">Message</label>
                    <textarea id="message" name="message" rows="4" placeholder="Tell us about your rental needs..."
                        maxlength="500"></textarea>
                </div>
                <button type="submit" class="submit-btn btn-form">Submit Inquiry</button>
            </form>
        </div>
    </div>
</section>